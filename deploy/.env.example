# Copy to deploy/.env and fill in. The deploy script sources this automatically.
AWS_REGION=us-east-1
KEY_NAME=my-ec2-keypair
KEY_PATH=/home/me/.ssh/my-ec2-keypair.pem

# optional overrides
STACK_NAME=freshchain
INSTANCE_TYPE=t3.large
# SSH_CIDR=1.2.3.4/32      # defaults to your detected public IP
APP_CIDR=0.0.0.0/0
